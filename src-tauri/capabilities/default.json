{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "dialog:allow-open",
    "fs:allow-read-dir",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir"
  ]
}