{
  "app-id": "com.sll.optitux-gui",
  "runtime": "org.gnome.Platform",
  "runtime-version": "45",
  "sdk": "org.gnome.Sdk",
  "command": "optitux",
  "separate-locales": false,
  "finish-args": [
    "--share=network",
    "--share=ipc",
    "--socket=wayland",
    "--socket=fallback-x11",
    "--device=dri",
    "--filesystem=host",
    "--talk-name=org.freedesktop.Notifications"
  ],
  "modules": [
    {
      "name": "optitux",
      "buildsystem": "simple",
      "build-commands": [
        "install -D optitux /app/bin/optitux",
        "mkdir -p /app/share/icons",
        "cp -r usr/share/icons/* /app/share/icons/",
        "find /app/share/icons -name \"optitux_gui.png\" -execdir mv {} com.sll.optitux-gui.png \\;",
        "sed -i 's/Icon=optitux-gui/Icon=com.sll.optitux-gui/' usr/share/applications/OptiTux.desktop || sed -i 's/Icon=optitux_gui/Icon=com.sll.optitux-gui/' usr/share/applications/OptiTux.desktop",
        "sed -i 's/Exec=optitux_gui/Exec=optitux/' usr/share/applications/OptiTux.desktop || true",
        "install -D usr/share/applications/OptiTux.desktop /app/share/applications/com.sll.optitux-gui.desktop"
      ],
      "sources": [
        {
          "type": "dir",
          "path": "flatpak_app"
        }
      ]
    }
  ]
}